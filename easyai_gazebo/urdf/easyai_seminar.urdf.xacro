  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${WHEEL_MASS}"/>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <inertia 
        ixx="${0.5*WHEEL_MASS*WHEEL_RAD*WHEEL_RAD}"
        iyy="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        izz="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        ixy="0.0" ixz="0.0" iyz="0.0"
      />
    </inertial>
  </link>
  
  
  <link name="back_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${WHEEL_MASS}"/>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <inertia 
        ixx="${0.5*WHEEL_MASS*WHEEL_RAD*WHEEL_RAD}"
        iyy="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        izz="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        ixy="0.0" ixz="0.0" iyz="0.0"
      />
    </inertial>
  </link>
  
  
  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${WHEEL_MASS}"/>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <inertia 
        ixx="${0.5*WHEEL_MASS*WHEEL_RAD*WHEEL_RAD}"
        iyy="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        izz="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        ixy="0.0" ixz="0.0" iyz="0.0"
      />
    </inertial>
  </link>
  
  
  <link name="back_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${WHEEL_RAD}" length="${WHEEL_WID}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${WHEEL_MASS}"/>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <inertia 
        ixx="${0.5*WHEEL_MASS*WHEEL_RAD*WHEEL_RAD}"
        iyy="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        izz="${(1.0/12.0)*WHEEL_MASS*(3*WHEEL_RAD*WHEEL_RAD + WHEEL_WID*WHEEL_WID)}"
        ixy="0.0" ixz="0.0" iyz="0.0"
      />
    </inertial>
  </link>
  
  
  
  


  <!-- base_link는 지면 좌표, base_chassis 지면으로부터 떨어져 있는 실제 로봇 몸통 중심 높이(바퀴 크기 + 로봇 몸통 중간-->
  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 ${BASE_HIG/2 +WHEEL_RAD*2}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base_chassis"/>
  </joint> 


  <joint name="imu_joint" type="fixed">
    <origin xyz="${BASE_LEN/2 - IMU_X_SEP} 0 ${IMU_HIG/2}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child link="imu"/>
  </joint>


  <!--
  좌/우 베이스: y=±(실린더 길이/2), z는 베이스 높이 맞춤
  좌/우 베이스 고정
  <joint name="vms_cylinder_base_joint_left" type="fixed">
    <origin xyz="${BASE_LEN/2 - VMS_CYLINDER_X_LEN} ${ VMS_CYLINDER_WID/2} ${BASE_HIG/2 + VMS_CYLINDER_BASE_HIG/2}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child  link="vms_cylinder_base_left"/>
  </joint>

  <joint name="vms_cylinder_base_joint_right" type="fixed">
    <origin xyz="${BASE_LEN/2 - VMS_CYLINDER_X_LEN} ${-VMS_CYLINDER_WID/2} ${BASE_HIG/2 + VMS_CYLINDER_BASE_HIG/2}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child  link="vms_cylinder_base_right"/>
  </joint>

  힌지도 같은 x/z로
  <joint name="vms_cylinder_joint" type="fixed">
    <origin xyz="${BASE_LEN/2 - VMS_CYLINDER_X_LEN} 0 ${BASE_HIG/2 + VMS_CYLINDER_BASE_HIG/2}" rpy="0 ${PI/2} 0"/>
    <parent link="base_chassis"/>
    <child  link="vms_cylinder"/>
  </joint>
  
  <joint name="vms_joint" type="fixed">
    <origin xyz="${-VMS_LEN/2} 0 ${VMS_CYLINDER_BASE_HIG/2}" rpy="0 0 0"/>
    <parent link="vms_cylinder"/>
    <child  link="vms_base"/>
  </joint>
    
  
  
  VMS 카메라
  <joint name="vms_camera_joint" type="fixed">
    <origin xyz="-${VMS_LEN/2 - CAMERA_X_LEN} 0 ${VMS_HIG/2 + CAMERA_HIG/2}" rpy="0 -${90*PI/180} 0"/>
    <parent link="vms_base"/>
    <child link="vms_camera"/>
  </joint>
  
  [1] 위치 이동 + YAW=+45°를 먼저 적용
  <joint name="vms_left_camera_yaw_joint" type="fixed">
    <origin
      xyz="-${VMS_LEN/2 + CAMERA_HIG/2} -${VMS_WID/2 - LEFT_CAMERA_Y_LEN} 0" rpy="${45*PI/180} 0 0"/>
    <parent link="vms_base"/>
    <child  link="vms_left_camera_yaw_link"/>
  </joint>
  
  [2] 그 다음 PITCH/ROLL만 적용 (예: 좌측을 바라보게 pitch=-90°)
  <joint name="vms_left_camera_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 -${90*PI/180} 0"/>
    <parent link="vms_left_camera_yaw_link"/>
    <child  link="vms_left_camera"/>
  </joint>
 
 
  <joint name="vms_back_camera_joint" type="fixed">
    <origin xyz="-${VMS_LEN/2 - BACK_CAMERA_X_LEN} 0 -${VMS_HIG/2 + CAMERA_HIG/2}" rpy="-${180*PI/180} ${90*PI/180} 0"/>
    <parent link="vms_base"/>
    <child link="vms_back_camera"/>
  </joint>
 
 
  VMS GPS
  <joint name="vms_gps_joint" type="fixed">
    <origin xyz="-${VMS_LEN/2 + GPS_ANTENNA_HIG/2} 0 0" rpy="0 -${PI/2} 0"/>
    <parent link="vms_base"/>
    <child link="vms_gps"/>
  </joint>
  
   -->
  
  <!-- 몸통 GPS -->
  <!-- <joint name="base_link_gps_joint" type="fixed">
    <origin xyz="-${BASE_LEN/2 - BASE_GPS_ANTENNA_SEP} 0 ${BASE_HIG/2}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child link="base_link_gps"/>    
  </joint> -->


  <!--바퀴 -->	
  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="${WHEEL_LEN_SEP/2} ${WHEEL_WID_SEP/2} ${-(WHEEL_RAD + BASE_HIG/2)}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>
     
  <joint name="back_left_wheel_joint" type="continuous">
    <origin xyz="-${WHEEL_LEN_SEP/2} ${WHEEL_WID_SEP/2} ${-(WHEEL_RAD+ BASE_HIG/2)}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child link="back_left_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="${WHEEL_LEN_SEP/2} -${WHEEL_WID_SEP/2} ${-(WHEEL_RAD + BASE_HIG/2)}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="back_right_wheel_joint" type="continuous">
    <origin xyz="-${WHEEL_LEN_SEP/2} -${WHEEL_WID_SEP/2} ${-(WHEEL_RAD + BASE_HIG/2)}" rpy="0 0 0"/>
    <parent link="base_chassis"/>
    <child link="back_right_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  
