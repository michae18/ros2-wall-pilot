  <!--skid_steer_drive_controller-->
  <!-- 4륜차-->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="skid_steer_drive_controller"> <!-- 4륜차-->
      <ros>
        <namespace>/easyai</namespace>
        <remapping>/cmd_vel:=/cmd_vel</remapping> <!--<argument>/cmd_vel:=cmd_vel</argument>-->
        <remapping>/odom:=/odom</remapping>
      </ros>
      <update_rate>100.0</update_rate>
      <num_wheel_pairs>2</num_wheel_pairs>
      <odometry_frame>odom</odometry_frame>
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>back_left_wheel_joint</left_joint>      
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>back_right_wheel_joint</right_joint>
      <wheel_radius>${WHEEL_RAD}</wheel_radius>
      <wheel_diameter>${2*WHEEL_RAD}</wheel_diameter>
      <wheel_separation>${WHEEL_WID_SEP}</wheel_separation>
      <robot_base_frame>base_link</robot_base_frame>
     		
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>
</robot>