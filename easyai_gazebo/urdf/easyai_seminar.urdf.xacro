    </collision>
    
    <inertial>
      <mass value="${WHEEL_BASE_MASS}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${WHEEL_BASE_MASS/12.0 * (WHEEL_BASE_WID*WHEEL_BASE_WID + WHEEL_BASE_HIG*WHEEL_BASE_HIG)}"
        iyy="${WHEEL_BASE_MASS/12.0 * (WHEEL_BASE_LEN*WHEEL_BASE_LEN + WHEEL_BASE_HIG*WHEEL_BASE_HIG)}"
        izz="${WHEEL_BASE_MASS/12.0 * (WHEEL_BASE_LEN*WHEEL_BASE_LEN + WHEEL_BASE_WID*WHEEL_BASE_WID)}"
