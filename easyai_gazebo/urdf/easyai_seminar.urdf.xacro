  <!-- 라이다 -->
  <joint name="front_lidar_joint" type="fixed">
    <!-- <origin xyz="${BASE_LEN/2 - F_LIDAR_SEP_LEN} -${BASE_WID/2 - F_LIDAR_SEP_WID} ${BASE_HIG/2 + LIDAR_HIG/2}" rpy="0 ${17*PI/180} 0"/> 라이다만 17도로 변경하기라이다만 17도로 변경하기 -->
    <origin xyz="0 0 ${BASE_HIG/2 + LIDAR_HIG/2}" rpy="0 0 0"/> <!-- wall_pilot을 위해 기울기 0도로 수정 -->
    <parent link="base_chassis"/>
    <child link="front_lidar"/>
  </joint>
  
  <!-- <joint name="back_lidar_joint" type="fixed">
