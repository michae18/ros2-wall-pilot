    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${LIDAR_BASE_LEN} ${LIDAR_BASE_WID} ${LIDAR_BASE_HIG}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${LIDAR_BASE_MASS}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${LIDAR_BASE_MASS/12.0 * (LIDAR_BASE_WID*LIDAR_BASE_WID + LIDAR_BASE_HIG*LIDAR_BASE_HIG)}"
        iyy="${LIDAR_BASE_MASS/12.0 * (LIDAR_BASE_LEN*LIDAR_BASE_LEN + LIDAR_BASE_HIG*LIDAR_BASE_HIG)}"
        izz="${LIDAR_BASE_MASS/12.0 * (LIDAR_BASE_LEN*LIDAR_BASE_LEN + LIDAR_BASE_WID*LIDAR_BASE_WID)}"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>
      

