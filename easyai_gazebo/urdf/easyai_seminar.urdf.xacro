  <link name="front_lidar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${LIDAR_RAD}" length="${LIDAR_HIG}"/>
      </geometry>
      <material name="blue_green"/>
    </visual> 
  
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${LIDAR_RAD}" length="${LIDAR_HIG}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${LIDAR_MASS}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${0.5*LIDAR_MASS*LIDAR_HIG*LIDAR_HIG}"
