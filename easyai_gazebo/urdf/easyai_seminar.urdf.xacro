    <origin xyz="-${BASE_LEN/2 - B_LIDAR_SEP_LEN} ${BASE_WID/2 - B_LIDAR_SEP_WID} ${BASE_HIG/2 + LIDAR_HIG/2}" rpy="0 0 ${PI}"/>
