  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  
  <material name="mid_dark">
    <color rgba="0.40 0.40 0.40 1.0"/>
  </material>
  
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="blue_green">
    <color rgba="0 1.0 1.0 1.0"/>
  </material>
  
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  
  
  

  <link name="base_link"/>

  <link name="base_chassis">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${BASE_LEN} ${BASE_WID} ${BASE_HIG}"/>
      </geometry>
      <material name="dark"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${BASE_LEN} ${BASE_WID} ${BASE_HIG}"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="${BASE_LINK_MASS}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${BASE_LINK_MASS/12.0 * (BASE_WID*BASE_WID + BASE_HIG*BASE_HIG)}"
        iyy="${BASE_LINK_MASS/12.0 * (BASE_LEN*BASE_LEN + BASE_HIG*BASE_HIG)}"
        izz="${BASE_LINK_MASS/12.0 * (BASE_LEN*BASE_LEN + BASE_WID*BASE_WID)}"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>



  <link name="imu">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${IMU_LEN} ${IMU_WID} ${IMU_HIG}"/>
      </geometry>
      <material name="mid_dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${IMU_LEN} ${IMU_WID} ${IMU_HIG}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="${IMU_MASS}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${IMU_MASS/12.0 * (IMU_WID*IMU_WID + IMU_HIG*IMU_HIG)}"
        iyy="${IMU_MASS/12.0 * (IMU_LEN*IMU_LEN + IMU_HIG*IMU_HIG)}"
        izz="${IMU_MASS/12.0 * (IMU_LEN*IMU_LEN + IMU_WID*IMU_WID)}"
        ixy="0" ixz="0" iyz="0"
      />
    </inertial>
  </link>


  

