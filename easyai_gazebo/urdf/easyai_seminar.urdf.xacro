  <gazebo reference="front_lidar">
    <material>Gazebo/Darkgray</material>
    <sensor name="front_lidar_senser" type="ray">
      <visualize>true</visualize>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples> <!-- 라이다 포인트 수 : 180개-->
            <resolution>1</resolution> <!-- 라이다 포인터 간 각도 : 1도-->
            <!-- <max_angle>3.14</max_angle> 왼쪽 100 도
            <min_angle>-3.14</min_angle>오른쪽 100도 -->
            <max_angle>3.14</max_angle>
            <min_angle>-3.14</min_angle>
          </horizontal> <!-- 라이다 범위 : 180도 , 포인트 수 : 180 , 포인터 간 각도 : 1도-->
        </scan>
        <range><!-- ydlidar 기준 0.12~10.0까지 가능 -->
          <min>0.2</min> <!-- 20cm부터-->
          <max>5.0</max> <!-- 5m까지 -->
        </range>
      </ray>
      <plugin name="front_lidar_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>

          <argument>~/out:=/scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frameName>front_lidar</frameName>
        <updateRate>10.0</updateRate>
      </plugin>
    </sensor>
  </gazebo>

