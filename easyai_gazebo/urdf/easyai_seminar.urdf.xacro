    <child link="back_lidar"/>
  </joint>
  
    
  
  <joint name="front_lidar_base_joint" type="fixed">
    <origin xyz="${BASE_LEN/2 - F_LIDAR_SEP_LEN} -${BASE_WID/2 - F_LIDAR_SEP_WID} ${BASE_HIG/2 + LIDAR_BASE_HIG/2}" rpy="0 0 0"/> 
    <parent link="base_chassis"/>
    <child link="front_lidar_base"/>
  </joint>
  
  
  <joint name="back_lidar_base_joint" type="fixed">
    <origin xyz="-${BASE_LEN/2 - B_LIDAR_SEP_LEN} ${BASE_WID/2 - B_LIDAR_SEP_WID} ${BASE_HIG/2 + LIDAR_BASE_HIG/2}" rpy="0 0 ${PI}"/>
    <parent link="base_chassis"/>
    <child link="back_lidar_base"/>
  </joint>
  -->

  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>
